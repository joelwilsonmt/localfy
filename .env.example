# Copy this to .env and fill in your values

# Required: create a Spotify app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Local dev: use the loopback IP (localhost is not accepted by Spotify)
# Server:    use your HTTPS domain, e.g. https://localfy.yourdomain.com/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/auth/callback

# Where to store music and app data ON THE HOST (maps into the container as /music and /data)
# Use absolute paths or paths relative to this directory. ~ is supported.
MUSIC_HOST_PATH=~/Music/localfy
DATA_HOST_PATH=~/Music/localfy/data

# These control paths INSIDE the container — leave them as-is
DOWNLOAD_PATH=/music
DATA_PATH=/data

AUDIO_FORMAT=mp3
AUDIO_BITRATE=320k
